# Backend
LLM_PROVIDER=nim
SUPPORTFLOW_DB_PATH=./supportflow.db
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=4096

# NVIDIA NIM default provider
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_API_KEY=
NIM_MODEL=mistralai/ministral-14b-instruct-2512

# Ollama fallback provider
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Optional GitHub import token
GITHUB_TOKEN=

# Optional Stack Exchange API key for higher quota
STACK_EXCHANGE_KEY=

# Frontend, only needed when backend is not proxied by Vite
VITE_API_BASE_URL=
